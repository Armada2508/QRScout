                "required": true,
                "defaultValue": "",
                "formResetBehavior": "reset",
                "choices": {
                    "swerve": "Swerve",
                    "west/tank": "West Coast/Tank",
                    "butterfly": "Butterfly/Grasshopper",
                    "mechanum": "Mechanum",
                    "other": "Other"
                },
                "code": "drv"
            },
            {
                "title": "Drivebase Motors",
                "type": "select",
                "description": "What motors are they using to drive (not turning)",
                "required": true,
                "defaultValue": "",
                "formResetBehavior": "reset",
                "choices": {
                    "Kraken": "Kraken",
                    "Falcon": "Falcon",
                    "Neo": "Neo",
                    "Vortex": "Vortex",
                    "other": "Other"
                },
                "code": "drvmot",
                "multiSelect": true
