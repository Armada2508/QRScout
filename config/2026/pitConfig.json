                "required": true,
                "defaultValue": "",
                "formResetBehavior": "reset",
                "code": "gearratio"
            },
            {
                "title": "Programming Language",
                "type": "select",
                "description": "What programming language does their robot primarily use?",
                "required": true,
                "defaultValue": "Unknown",
                "formResetBehavior": "reset",
                "choices": {
                    "java": "Java",
                    "C++": "C++",
                    "python": "Python",
                    "other": "other"
                },
                "code": "prglan"
            },
            {
                "title": "Automatic Alignment",
