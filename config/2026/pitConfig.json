            {
                "title": "Length",
                "type": "number",
                "description": "Lenth of the robots drivebase (in inches pls)",
                "required": true,
                "defaultValue": 0,
                "formResetBehavior": "reset",
                "code": "len"
            },
            {
                "title": "Width",
                "type": "number",
                "description": "Width of the robots drivebase (in inches pls)",
                "required": true,
                "defaultValue": 0,
                "formResetBehavior": "reset",
                "code": "wid"
            },
            {
                "title": "Height",
                "type": "number",
                "description": "The height of the robot (in inches pls)",
                "required": true,
                "defaultValue": 0,
                "formResetBehavior": "reset",
                "code": "high"
