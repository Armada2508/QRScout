                "type": "select",
                "required": true,
                "code": "pickLoc",
                "defaultValue": "",
                "choices": {
                    "none": "None",
                    "ground": "Ground",
                    "outpost": "Outpost",
                    "both": "Both"
                },
                "multiSelect": false
            },
            {
                "title": "Bumper Clearance",
                "type": "number",
                "description": "How far off the ground is their robot's bumpers?",
                "required": true,
                "defaultValue": 0,
                "formResetBehavior": "reset",
                "code": "bumClr"
            },
            {
                "title": "Shooter Speed",
                "type": "number",
                "description": "The speed of their shooter in RPM",
                "required": true,
                "defaultValue": 0,
                "formResetBehavior": "reset",
                "code": "SS"
            },
            {
                "title": "Turret or Fixed?",
